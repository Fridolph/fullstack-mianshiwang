{
  "name": "fullstack-mianshiwang",
  "version": "1.0.0",
  "description": "Monorepo for fullstack interview website project",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter='./apps/*' --continue",
    "dev:all": "turbo run dev --filter='./apps/*' --continue",
    "dev:client": "turbo run dev --filter=@mianshiwang/client",
    "dev:server": "turbo run dev --filter=@mianshiwang/ww-server",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fridolph/fullstack-mianshiwang.git"
  },
  "keywords": [
    "monorepo",
    "fullstack",
    "nuxt",
    "nestjs"
  ],
  "pnpm": {
    "overrides": {
      "vue": "npm:vue@3.5.22",
      "better-sqlite3": "8.6.0"
    }
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Fridolph/fullstack-mianshiwang/issues"
  },
  "homepage": "https://github.com/Fridolph/fullstack-mianshiwang#readme",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@nuxtjs/tailwindcss": "6.14.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "turbo": "^2.9.3"
  }
}
